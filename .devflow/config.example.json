{
  "$schema": "./config.schema.json",
  "base_branch": "main",
  "claude_model": "claude-opus-4-8",
  "devflow_version": "",
  "devflow": {
    "allowed_bots": "claude,dependabot",
    "allowed_users": "*",
    "workpad_marker": "<!-- devflow:workpad -->",
    "effort": "high",
    "allowed_tools": [],
    "execution_diagnostics_enabled": true,
    "execution_transcript_artifact_enabled": false
  },
  "devflow_implement": {
    "effort": "high",
    "implement_pr_state": "ready_for_review",
    "allowed_tools": [],
    "stall_backstop": {
      "enabled": true,
      "max_resume_attempts": 2
    }
  },
  "devflow_runner": {
    "effort": "high",
    "provision_env": false,
    "allowed_tools": []
  },
  "devflow_review_and_fix": {
    "fix_severity_threshold": "important",
    "max_iterations": 5,
    "efficiency_telemetry_enabled": true,
    "efficiency_cut_candidate_min_dispatch": 3
  },
  "devflow_review": {
    "verdict_severity_threshold": "critical",
    "live_progress_comment_enabled": true,
    "require_up_to_date": true,
    "require_ci_green": true,
    "stall_backstop": {
      "enabled": true,
      "max_resume_attempts": 2
    },
    "agent_overrides": {
      "default": {
        "effort": "high"
      },
      "devflow:checklist-deduper": {
        "model": "claude-sonnet-4-6",
        "effort": "medium"
      },
      "devflow:code-reviewer": {
        "model": "claude-opus-4-8",
        "effort": "high",
        "iterations": "first-only"
      }
    }
  },
  "receiving_review": {
    "fix_severity_threshold": "critical"
  },
  "setup": {
    "python_version": "3.11",
    "node_version": "",
    "install": [
      "python -m pip install pyyaml"
    ]
  },
  "docs": {
    "internal": "docs/internal/",
    "external": "docs/external/",
    "internal_enabled": true,
    "external_enabled": true,
    "release_notes_file": "docs/external/release-notes.md",
    "changelog_file": "CHANGELOG.md",
    "labels": "Documented"
  },
  "deferred": {
    "labels": "DevFlow,Deferred"
  },
  "devflow_retrospective": {
    "enabled": true,
    "retrospective_model": "claude-sonnet-4-6",
    "audit_model": "claude-opus-4-8",
    "implementation_branch_prefix": "claude/",
    "min_occurrences": 2,
    "cooldown_days": 3,
    "max_prs_per_run": 500,
    "diff_byte_cap": 204800
  },
  "workflows": {
    "devflow": true,
    "devflow-review": true
  }
}
