{
  "$schema": "./config.schema.json",
  "base_branch": "main",
  "claude_model": "claude-opus-4-8",
  "devflow_version": "main",
  "devflow": {
    "allowed_bots": "claude,dependabot,devflow-autopilot",
    "allowed_users": "*",
    "workpad_marker": "<!-- devflow:workpad -->",
    "effort": "low",
    "allowed_tools": [
      "Bash(lib/test/run.sh:*)",
      "Bash(lib/test/run-module.sh:*)",
      "Bash(lib/preflight.sh:*)",
      "Bash(lib/test/prompt-mass-census.py:*)",
      "Bash(shellcheck:*)"
    ],
    "execution_diagnostics_enabled": true,
    "execution_transcript_artifact_enabled": true
  },
  "devflow_implement": {
    "effort": "low",
    "implement_pr_state": "ready_for_review",
    "allowed_tools": [
      "Bash(lib/test/run.sh:*)",
      "Bash(lib/test/run-module.sh:*)",
      "Bash(lib/preflight.sh:*)",
      "Bash(lib/test/prompt-mass-census.py:*)",
      "Bash(shellcheck:*)",
      "Bash(chmod:*)",
      "Bash(git ls-remote:*)",
      "Bash(git check-ignore:*)"
    ],
    "stall_backstop": {
      "enabled": true,
      "max_resume_attempts": 2
    }
  },
  "devflow_runner": {
    "effort": "low",
    "provision_env": false,
    "allowed_tools": []
  },
  "devflow_review_and_fix": {
    "fix_severity_threshold": "suggestion",
    "max_iterations": 5,
    "efficiency_telemetry_enabled": true,
    "efficiency_cut_candidate_min_dispatch": 3
  },
  "devflow_review": {
    "verdict_severity_threshold": "critical",
    "live_progress_comment_enabled": true,
    "stale_prose": {
      "enabled": true,
      "severity": "important"
    },
    "require_up_to_date": true,
    "require_ci_green": true,
    "agent_overrides": {
      "default": {
        "effort": "low"
      },
      "devflow:checklist-deduper": {
        "model": "claude-sonnet-5",
        "effort": "low"
      },
      "devflow:code-reviewer": {
        "model": "claude-opus-4-8",
        "effort": "low",
        "iterations": "first-only"
      }
    }
  },
  "receiving_review": {
    "fix_severity_threshold": "suggestion"
  },
  "setup": {
    "python_version": "3.11",
    "node_version": "",
    "install": [
      "python -m pip install -r requirements.txt"
    ],
    "git_dir_pin": false,
    "git_work_tree_pin": false
  },
  "docs": {
    "internal": "docs/",
    "external": "docs/",
    "internal_enabled": true,
    "external_enabled": false,
    "release_notes_file": "",
    "changelog_file": "CHANGELOG.md",
    "labels": "Documented"
  },
  "deferred": {
    "labels": "DevFlow,Deferred"
  },
  "devflow_retrospective": {
    "enabled": true,
    "retrospective_model": "claude-opus-4-8",
    "audit_model": "claude-opus-4-8",
    "implementation_branch_prefix": "claude/",
    "min_occurrences": 2,
    "cooldown_days": 3,
    "max_prs_per_run": 500,
    "diff_byte_cap": 204800
  },
  "workflows": {
    "devflow": true,
    "devflow-review": true
  },
  "verification_flight": {
    "enabled": true,
    "lease_seconds": 900,
    "wait_timeout_seconds": 600,
    "profiles": {}
  }
}
