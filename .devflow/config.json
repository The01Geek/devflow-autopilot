{
  "$schema": "./config.schema.json",
  "base_branch": "main",
  "claude_model": "claude-opus-4-8",
  "devflow_version": "",
  "devflow": {
    "allowed_bots": "claude,dependabot,devflow-autopilot",
    "allowed_users": "*",
    "workpad_marker": "<!-- devflow:workpad -->",
    "effort": "low",
    "allowed_tools": []
  },
  "devflow_implement": {
    "effort": "low",
    "allowed_tools": [],
    "implement_pr_state": "ready_for_review"
  },
  "devflow_runner": {
    "effort": "low",
    "provision_env": false,
    "allowed_tools": []
  },
  "devflow_review_and_fix": {
    "fix_severity_threshold": "important",
    "max_iterations": 5,
    "efficiency_telemetry_enabled": true,
    "efficiency_cut_candidate_min_dispatch": 3
  },
  "devflow_review": {
    "verdict_severity_threshold": "critical",
    "live_progress_comment_enabled": true,
    "agent_overrides": {
      "default": {
        "effort": "low"
      },
      "devflow:checklist-deduper": {
        "model": "claude-sonnet-4-6",
        "effort": "low"
      },
      "devflow:code-reviewer": {
        "model": "claude-opus-4-8",
        "effort": "low"
      }
    }
  },
  "receiving_review": {
    "fix_severity_threshold": "important"
  },
  "setup": {
    "python_version": "3.11",
    "node_version": "",
    "install": [
      "python -m pip install -r requirements.txt"
    ]
  },
  "docs": {
    "internal": "docs/",
    "external": "docs/",
    "internal_enabled": true,
    "external_enabled": false,
    "release_notes_file": "CHANGELOG.md",
    "labels": "Documented"
  },
  "deferred": {
    "labels": "DevFlow,Deferred"
  },
  "devflow_retrospective": {
    "enabled": true,
    "retrospective_model": "claude-opus-4-8",
    "audit_model": "claude-opus-4-8",
    "implementation_branch_prefix": "claude/",
    "min_occurrences": 2,
    "cooldown_days": 3,
    "max_prs_per_run": 500,
    "diff_byte_cap": 204800
  },
  "workflows": {
    "devflow": true,
    "devflow-review": true
  }
}
