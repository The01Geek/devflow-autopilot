{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "DevFlow per-language tool presets. Single source of truth for `/devflow:init` (via scripts/detect-project-tools.sh) — detects each language by its marker file(s) and unions the matching `allowed_tools` into config.devflow.allowed_tools, devflow_implement.allowed_tools, and devflow_runner.allowed_tools, plus contributes to the shared `setup` block. Edit here; do NOT hand-list tools in a repo's config.json. SECURITY: anything listed here can run a PR author's code during the automated review (pull_request_target + write token) — keep entries to mainstream build/test/lint tools and resolve which install command to use from the present lockfile (see scripts/detect-project-tools.sh).",
  "presets": {
    "node": {
      "markers": ["package.json"],
      "allowed_tools": [
        "Bash(node:*)",
        "Bash(npm:*)",
        "Bash(npx:*)",
        "Bash(pnpm:*)",
        "Bash(yarn:*)",
        "Bash(corepack:*)",
        "Bash(tsc:*)",
        "Bash(eslint:*)",
        "Bash(prettier:*)",
        "Bash(jest:*)",
        "Bash(vitest:*)",
        "Bash(webpack:*)",
        "Bash(vite:*)",
        "Bash(rollup:*)",
        "Bash(esbuild:*)"
      ],
      "setup": { "node_version": "20" }
    },
    "go": {
      "markers": ["go.mod"],
      "allowed_tools": [
        "Bash(go:*)",
        "Bash(gofmt:*)",
        "Bash(golangci-lint:*)"
      ]
    },
    "rust": {
      "markers": ["Cargo.toml"],
      "allowed_tools": [
        "Bash(cargo:*)",
        "Bash(rustc:*)",
        "Bash(rustfmt:*)"
      ]
    },
    "java": {
      "markers": ["pom.xml", "build.gradle", "build.gradle.kts", "gradlew", "settings.gradle"],
      "allowed_tools": [
        "Bash(mvn:*)",
        "Bash(./mvnw:*)",
        "Bash(gradle:*)",
        "Bash(./gradlew:*)"
      ]
    },
    "ruby": {
      "markers": ["Gemfile"],
      "allowed_tools": [
        "Bash(ruby:*)",
        "Bash(bundle:*)",
        "Bash(rake:*)",
        "Bash(rspec:*)",
        "Bash(rubocop:*)"
      ]
    },
    "php": {
      "markers": ["composer.json"],
      "allowed_tools": [
        "Bash(php:*)",
        "Bash(composer:*)",
        "Bash(phpunit:*)",
        "Bash(./vendor/bin/phpunit:*)",
        "Bash(./vendor/bin/phpstan:*)",
        "Bash(./vendor/bin/php-cs-fixer:*)"
      ]
    },
    "dotnet": {
      "markers": ["*.csproj", "*.sln", "*.fsproj"],
      "allowed_tools": [
        "Bash(dotnet:*)"
      ]
    },
    "make": {
      "markers": ["Makefile", "makefile", "GNUmakefile"],
      "allowed_tools": [
        "Bash(make:*)"
      ]
    },
    "docker": {
      "markers": ["Dockerfile", "docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml"],
      "allowed_tools": [
        "Bash(docker:*)",
        "Bash(docker compose:*)",
        "Bash(docker-compose:*)"
      ]
    }
  }
}
