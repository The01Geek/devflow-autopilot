# DevFlow ephemeral working state (review caches, weekly-loop temp files).
# Keep the committed learnings/ overrides; ignore everything else under .devflow/.
/.devflow/
!/.devflow/learnings/
/.devflow-scratch/
/.devflow-tmp/

# Adopter's live config (copied from project-config.example.yml). Not shipped;
# each adopter creates their own. Force-add with `git add -f` if you dogfood
# DevFlow on this very repo and want its cloud workflows to read it.
/.github/project-config.yml

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS / editor
.DS_Store
*.swp

# Private maintainer working docs — never publish (kept outside the repo).
/devflow-roadmap.md
*.private.md
